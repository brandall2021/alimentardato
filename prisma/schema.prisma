generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TipoDocumento {
  DNI
  LE
  LC
  PASAPORTE
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("ADMIN")
  createdAt     DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Configuracion {
  id    String @id @default(cuid())
  clave String @unique
  valor String
}

model Consulta {
  id        String   @id @default(cuid())
  usuario   String
  email     String?
  tipo      String
  valores   String
  resultados Int     @default(0)
  filtros   String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([usuario])
}

model Alumno {
  id                  String        @id @default(cuid())
  apellidoNombre      String
  tipoDocumento       TipoDocumento @default(DNI)
  numeroDocumento     String
  fechaNacimiento     DateTime?
  email               String?
  telefono            String?
  legajo              String?
  plan                String?
  anoIngreso          Int?
  fechaIngreso        DateTime?
  ultimoExamen        DateTime?
  ultimaReinscripcion DateTime?
  promConAplazos      Float?
  promSinAplazos      Float?
  actividadesAprobadas Int?
  totalActividades    Int?
  estadoInscripcion   String?
  paisOrigen          String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@unique([tipoDocumento, numeroDocumento])
  @@index([numeroDocumento])
  @@index([legajo])
  @@index([email])
  @@index([plan])
  @@index([anoIngreso])
  @@index([estadoInscripcion])
}
