# Base de datos PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/alimentardato?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="genera-con-openssl-rand-base64-32"

# OAuth — Google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# OAuth — GitHub
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Email admin permitido para OAuth
ADMIN_EMAIL="admin@example.com"

# Credenciales de desarrollo (opcional — también se pueden configurar desde /admin/configuracion)
# DEV_EMAIL="admin@alimentardato.com"
# DEV_PASSWORD="admin123"
